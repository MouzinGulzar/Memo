generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id              String              @id @default(cuid())
  apiKey          String              @unique
  phone           String              @unique
  name            String?
  password        String?
  createdAt       DateTime            @default(now())
  messages        Message[]
  phoneNumbers    UserPhoneNumber[]
  whatsAppSession WhatsAppSession?
  userSkills      UserSkill[]
  entities        Entity[]
  memories        Memory[]
  relationships   Relationship[]
  actions         Action[]
  conversationEvents ConversationEvent[]
  cognitiveSessions CognitiveSession[]
}

model WhatsAppSession {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  creds     String
  keys      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPhoneNumber {
  id        String   @id @default(cuid())
  userId    String
  phone     String   @unique
  label     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  key  String @unique
  name String

  shortDescription String? @map("short_description")
  description      String?

  category String?

  capabilities Json @default("[]")

  supportedEntities Json @default("[]") @map("supported_entities")

  memoryCategories Json @default("[]") @map("memory_categories")

  supportedActions Json @default("[]") @map("supported_actions")

  supportedIntents Json @default("[]") @map("supported_intents")

  examplePrompts Json @default("[]") @map("example_prompts")

  triggers Json @default("[]")

  executionRules Json @default("{}") @map("execution_rules")

  metadata Json @default("{}")

  priority Int @default(0)

  isCoreSkill Boolean @default(false) @map("is_core_skill")

  sharedMemoryAccess Boolean @default(false) @map("shared_memory_access")

  crossSkillCompatible Boolean @default(false) @map("cross_skill_compatible")

  institutionalMemoryEnabled Boolean @default(false) @map("institutional_memory_enabled")

  historicalReasoningEnabled Boolean @default(false) @map("historical_reasoning_enabled")

  calendarAwarenessEnabled Boolean @default(false) @map("calendar_awareness_enabled")

  conflictDetectionEnabled Boolean @default(false) @map("conflict_detection_enabled")

  relationshipAwareScheduling Boolean @default(false) @map("relationship_aware_scheduling")

  relationshipTimelineEnabled Boolean @default(false) @map("relationship_timeline_enabled")

  historicalInteractionTracking Boolean @default(false) @map("historical_interaction_tracking")

  organizationalContinuityEnabled Boolean @default(false) @map("organizational_continuity_enabled")

  workforceAwarenessEnabled Boolean @default(false) @map("workforce_awareness_enabled")

  hiringWorkflowEnabled Boolean @default(false) @map("hiring_workflow_enabled")

  autonomousExecutionEnabled Boolean @default(false) @map("autonomous_execution_enabled")

  proactiveCapabilitiesEnabled Boolean @default(false) @map("proactive_capabilities_enabled")

  semanticSearchEnabled Boolean @default(false) @map("semantic_search_enabled")

  reasoningEnabled Boolean @default(false) @map("reasoning_enabled")

  orchestrationEnabled Boolean @default(true) @map("orchestration_enabled")

  isEnabled Boolean @default(true) @map("is_enabled")

  version String @default("1.0")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  userSkills UserSkill[]

  @@index([category])
  @@index([key])
  @@index([isEnabled])
  @@index([priority])
  @@map("skills")
}

model UserSkill {
  id        String   @id @default(cuid())
  userId    String
  skillId   String   @db.Uuid
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skills")
}

model Message {
  id               String   @id @default(cuid())
  userId           String
  platform         String
  userPhone        String
  type             String
  text             String?
  storageKey       String?
  mimeType         String?
  rawPayload       Json
  processedText    String?
  processingStatus String   @default("pending")
  intent           String?
  intentData       Json?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Universal node: person, task, reminder, project, organization, etc.
model Entity {
  id        String   @id @default(cuid())
  userId    String
  type      String
  name      String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  embedding Unsupported("vector(384)")?

  @@index([userId, type])
  @@index([userId])
}

// Universal cognitive storage: preferences, decisions, notes, context
model Memory {
  id              String   @id @default(cuid())
  userId          String
  entityId        String?
  category        String
  content         String
  sourceMessageId String?
  importanceScore Float?
  metadata        Json?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  embedding Unsupported("vector(384)")?

  @@index([userId, category])
  @@index([userId])
}

// Graph edges between entities
model Relationship {
  id           String   @id @default(cuid())
  userId       String
  fromEntityId String
  toEntityId   String
  relationship String
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromEntityId])
  @@index([toEntityId])
}

// Universal operations: tasks, reminders, follow-ups, appointments
model Action {
  id              String    @id @default(cuid())
  userId          String
  userPhone       String?
  type            String
  title           String
  status          String    @default("pending")
  entityId        String?
  sourceMessageId String?
  payload         Json?
  scheduledFor    DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
  @@index([userId, status])
  @@index([scheduledFor, status])
}

// Interaction timeline for conversation context
model ConversationEvent {
  id            String   @id @default(cuid())
  userId        String
  userPhone     String
  role          String
  message       String
  extractedData Json?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userPhone, createdAt])
}

// Short-term working memory per phone conversation
model CognitiveSession {
  id            String   @id @default(cuid())
  userId        String
  userPhone     String   @unique
  workingMemory Json
  expiresAt     DateTime
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
